# Configuración de Gemini AI (Opcional, prefiere artypan_GEMINI_API_KEY para evitar bloqueos)
VITE_GEMINI_API_KEY=tu_api_key_aqui

# Configuración alternativa de Gemini AI (Recomendada en Vercel)
artypan_GEMINI_API_KEY=tu_api_key_aqui

# Configuración de EmailJS (Opcional)
VITE_EMAILJS_SERVICE_ID=tu_service_id
VITE_EMAILJS_TEMPLATE_ID=tu_template_id
VITE_EMAILJS_PUBLIC_KEY=tu_public_key

# Configuración de Firebase Firestore (Para base de datos de pedidos)
VITE_FIREBASE_API_KEY=tu_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdefg
